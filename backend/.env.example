# Copy this file to backend/.env for optional service integrations.
# Keep backend/.env private; only this template belongs in git.
#
# Telegram account credentials are entered in the web platform and stored in
# data/runtime/accounts/. Do not put API_ID/API_HASH/PHONE here for the UI.

# Optional local browser origins for Vite dev mode. Leave empty for defaults:
# http://127.0.0.1:3000,http://localhost:3000
STUDIO_CORS_ORIGINS=

# Optional OpenAI settings for normalization workflows.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional DeepSeek settings for AI DOCX markup.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_SECONDS=240
DEEPSEEK_MAX_TOKENS=80000
